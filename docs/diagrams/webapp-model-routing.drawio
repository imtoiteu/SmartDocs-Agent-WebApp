<mxfile host="app.diagrams.net" type="device"><diagram name="W2 · Định tuyến mô hình AI theo tác vụ — Model Registry &amp; Router (WebApp)" id="webapp-model-routing"><mxGraphModel dx="900" dy="600" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1360" pageHeight="700" math="0" shadow="0"><root><mxCell id="0"/><mxCell id="1" parent="0"/><mxCell id="title" value="W2 · Định tuyến mô hình AI theo tác vụ — Model Registry &amp; Router (WebApp)" style="text;html=1;fontSize=20;fontStyle=1;verticalAlign=middle;align=left;fontColor=#10202E;" vertex="1" parent="1"><mxGeometry x="40" y="14" width="1280" height="32" as="geometry"/></mxCell><mxCell id="SET" value="Cài đặt → AI models" style="swimlane;rounded=1;arcSize=4;startSize=34;html=1;whiteSpace=wrap;fontSize=14;fontStyle=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;swimlaneFillColor=#F0F6FD;fontColor=#10202E;verticalAlign=middle;align=left;spacingLeft=8;" vertex="1" parent="1"><mxGeometry x="40" y="64" width="620" height="180" as="geometry"/></mxCell><mxCell id="CONS" value="Các consumer LLM (mọi lời gọi đều hỏi Router)" style="swimlane;rounded=1;arcSize=4;startSize=34;html=1;whiteSpace=wrap;fontSize=14;fontStyle=1;fillColor=#D5E8D4;strokeColor=#82B366;swimlaneFillColor=#EFF6EE;fontColor=#10202E;verticalAlign=middle;align=left;spacingLeft=8;" vertex="1" parent="1"><mxGeometry x="700" y="64" width="620" height="180" as="geometry"/></mxCell><mxCell id="ROUTE" value="Model Router — llm_gateway.resolve(task)" style="swimlane;rounded=1;arcSize=4;startSize=34;html=1;whiteSpace=wrap;fontSize=14;fontStyle=1;fillColor=#E1D5E7;strokeColor=#9673A6;swimlaneFillColor=#F3EFF5;fontColor=#10202E;verticalAlign=middle;align=left;spacingLeft=8;" vertex="1" parent="1"><mxGeometry x="40" y="270" width="1280" height="226" as="geometry"/></mxCell><mxCell id="REG" value="Model Registry — danh mục model (không bao giờ giữ khóa API)" style="swimlane;rounded=1;arcSize=4;startSize=34;html=1;whiteSpace=wrap;fontSize=14;fontStyle=1;fillColor=#FFF2CC;strokeColor=#D6B656;swimlaneFillColor=#FFFAEB;fontColor=#10202E;verticalAlign=middle;align=left;spacingLeft=8;" vertex="1" parent="1"><mxGeometry x="40" y="522" width="1280" height="142" as="geometry"/></mxCell><mxCell id="cfg1" value="Định tuyến theo tác vụ (task_models):&lt;br&gt;Chat / Hỏi đáp tài liệu · Tóm tắt · Viết lại AI · Agent" style="rounded=1;arcSize=12;whiteSpace=wrap;html=1;fontSize=11.5;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontColor=#15202B;" vertex="1" parent="SET"><mxGeometry x="24" y="40" width="572" height="48" as="geometry"/></mxCell><mxCell id="cfg2" value="Model dự phòng (fallback_model) — tùy chọn, chính sách tường minh" style="rounded=1;arcSize=12;whiteSpace=wrap;html=1;fontSize=11.5;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontColor=#15202B;" vertex="1" parent="SET"><mxGeometry x="24" y="96" width="572" height="36" as="geometry"/></mxCell><mxCell id="cfg3" value="Mặc định: Automatic (auto) = giữ nguyên hành vi trước đây" style="rounded=1;arcSize=12;whiteSpace=wrap;html=1;fontSize=11.5;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontColor=#15202B;" vertex="1" parent="SET"><mxGeometry x="24" y="138" width="572" height="36" as="geometry"/></mxCell><mxCell id="u1" value="Chat / Hỏi đáp tài liệu" style="rounded=1;arcSize=12;whiteSpace=wrap;html=1;fontSize=12;fillColor=#D5E8D4;strokeColor=#82B366;fontColor=#15202B;" vertex="1" parent="CONS"><mxGeometry x="24" y="40" width="286" height="48" as="geometry"/></mxCell><mxCell id="u2" value="Tóm tắt · Viết lại AI" style="rounded=1;arcSize=12;whiteSpace=wrap;html=1;fontSize=12;fillColor=#D5E8D4;strokeColor=#82B366;fontColor=#15202B;" vertex="1" parent="CONS"><mxGeometry x="330" y="40" width="266" height="48" as="geometry"/></mxCell><mxCell id="u3" value="Agent — lập kế hoạch &amp; tổng hợp (tác vụ “agent”)" style="rounded=1;arcSize=12;whiteSpace=wrap;html=1;fontSize=12;fillColor=#D5E8D4;strokeColor=#82B366;fontColor=#15202B;" vertex="1" parent="CONS"><mxGeometry x="24" y="104" width="572" height="48" as="geometry"/></mxCell><mxCell id="auto" value="auto → chuỗi legacy (offline-first):&lt;br&gt;Groq → Gemini → self-hosted → Qwen cục bộ&lt;br&gt;(cloud chỉ khi CÓ khóa và ĐƯỢC phép)" style="rounded=1;arcSize=12;whiteSpace=wrap;html=1;fontSize=11;fillColor=#E1D5E7;strokeColor=#9673A6;fontColor=#15202B;" vertex="1" parent="ROUTE"><mxGeometry x="24" y="40" width="390" height="76" as="geometry"/></mxCell><mxCell id="expl" value="Model chỉ định → kiểm tra:&lt;br&gt;còn tồn tại · hỗ trợ tác vụ · đã cấu hình&lt;br&gt;Local-only ⇒ chặn model cloud" style="rounded=1;arcSize=12;whiteSpace=wrap;html=1;fontSize=11;fillColor=#E1D5E7;strokeColor=#9673A6;fontColor=#15202B;" vertex="1" parent="ROUTE"><mxGeometry x="438" y="40" width="390" height="76" as="geometry"/></mxCell><mxCell id="err" value="Không đạt ⇒ RouteError (thông báo rõ, xử lý được)&lt;br&gt;KHÔNG âm thầm đổi model&lt;br&gt;KHÔNG fallback ngầm sang cloud" style="rounded=1;arcSize=12;whiteSpace=wrap;html=1;fontSize=11;fillColor=#F8CECC;strokeColor=#B85450;fontColor=#15202B;" vertex="1" parent="ROUTE"><mxGeometry x="852" y="40" width="404" height="76" as="geometry"/></mxCell><mxCell id="fit" value="Vừa khít ngữ cảnh: cắt prompt theo context_limit&lt;br&gt;của model (ưu tiên nội dung mới nhất)" style="rounded=1;arcSize=12;whiteSpace=wrap;html=1;fontSize=11;fillColor=#E1D5E7;strokeColor=#9673A6;fontColor=#15202B;" vertex="1" parent="ROUTE"><mxGeometry x="24" y="136" width="520" height="56" as="geometry"/></mxCell><mxCell id="fb" value="fallback_model (nếu đặt) chỉ được dùng khi vượt qua CÙNG các kiểm tra —&lt;br&gt;fallback bị chặn không bao giờ được thay thế vào" style="rounded=1;arcSize=12;whiteSpace=wrap;html=1;fontSize=11;fillColor=#E1D5E7;strokeColor=#9673A6;fontColor=#15202B;" vertex="1" parent="ROUTE"><mxGeometry x="568" y="136" width="688" height="56" as="geometry"/></mxCell><mxCell id="r0" value="Bundled local&lt;br&gt;Qwen cục bộ (CPU)&lt;br&gt;ctx ~4096" style="rou