<mxfile host="app.diagrams.net" type="device"><diagram name="W1 · Kiến trúc tổng thể SmartDocs WebApp" id="webapp-overall-architecture"><mxGraphModel dx="900" dy="600" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1360" pageHeight="800" math="0" shadow="0"><root><mxCell id="0"/><mxCell id="1" parent="0"/><mxCell id="title" value="W1 · Kiến trúc tổng thể SmartDocs WebApp" style="text;html=1;fontSize=20;fontStyle=1;verticalAlign=middle;align=left;fontColor=#10202E;" vertex="1" parent="1"><mxGeometry x="40" y="14" width="1280" height="32" as="geometry"/></mxCell><mxCell id="FE" value="Trình duyệt (máy khách) — SPA thuần JS, cùng cấu trúc UI với DesktopApp" style="swimlane;rounded=1;arcSize=4;startSize=34;html=1;whiteSpace=wrap;fontSize=14;fontStyle=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;swimlaneFillColor=#F0F6FD;fontColor=#10202E;verticalAlign=middle;align=left;spacingLeft=8;" vertex="1" parent="1"><mxGeometry x="40" y="64" width="1280" height="108" as="geometry"/></mxCell><mxCell id="BE" value="Flask backend — một tiến trình trên server (app.py)" style="swimlane;rounded=1;arcSize=4;startSize=34;html=1;whiteSpace=wrap;fontSize=14;fontStyle=1;fillColor=#D4E1F5;strokeColor=#3F61A8;swimlaneFillColor=#EEF3FB;fontColor=#10202E;verticalAlign=middle;align=left;spacingLeft=8;" vertex="1" parent="1"><mxGeometry x="40" y="196" width="1280" height="104" as="geometry"/></mxCell><mxCell id="SVC" value="Dịch vụ xử lý (services/ · agent/)" style="swimlane;rounded=1;arcSize=4;startSize=34;html=1;whiteSpace=wrap;fontSize=14;fontStyle=1;fillColor=#B0E3E6;strokeColor=#0E8088;swimlaneFillColor=#E0F4F5;fontColor=#10202E;verticalAlign=middle;align=left;spacingLeft=8;" vertex="1" parent="1"><mxGeometry x="40" y="324" width="1280" height="112" as="geometry"/></mxCell><mxCell id="ROUTE" value="Model Router — llm_gateway.resolve(task): Chat/QA · Tóm tắt · Viết lại AI · Agent" style="swimlane;rounded=1;arcSize=4;startSize=34;htm