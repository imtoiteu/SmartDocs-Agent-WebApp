<mxfile host="app.diagrams.net" type="device"><diagram name="21 · Chuỗi provider dự phòng — chế độ “auto” (legacy)" id="provider-fallback-chain-vi"><mxGraphModel dx="900" dy="600" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1240" pageHeight="740" math="0" shadow="0"><root><mxCell id="0"/><mxCell id="1" parent="0"/><mxCell id="title" value="21 · Chuỗi provider dự phòng — chế độ “auto” (legacy)" style="text;html=1;fontSize=20;fontStyle=1;verticalAlign=middle;align=left;fontColor=#10202E;" vertex="1" parent="1"><mxGeometry x="40" y="14" width="1160" height="32" as="geometry"/></mxCell><mxCell id="FB" value="FallbackProvider(chuỗi) — hạ cấp khi lỗi · ghi nhớ provider chạy được · chuỗi rỗng = lỗi rõ" style="swimlane;rounded=1;arcSize=4;startSize=34;html=1;whiteSpace=wrap;fontSize=14;fontStyle=1;fillColor=#FFF2CC;strokeColor=#D6B656;swimlaneFillColor=#FFFAEB;fontColor=#10202E;verticalAlign=middle;align=left;spacingLeft=8;" vertex="1" parent="1"><mxGeometry x="540" y="344" width="660" height="200" as="geometry"/></mxCell><mxCell id="gdp" value="get_default_provider()&lt;br&gt;đọc AGENT_LLM_PROVIDER (mặc định: auto)" style="rounded=1;arcSize=12;whiteSpace=wrap;html=1;fontSize=10.5;fillColor=#D4E1F5;strokeColor=#3F61A8;fontColor=#15202B;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="450" y="66" width="360" height="50" as="geometry"/></mxCell><mxCell id="sel" value="AGENT_LLM_PROVIDER?" style="rhombus;whiteSpace=wrap;html=1;fontSize=9.5;fillColor=#FFF2CC;strokeColor=#D6B656;fontColor=#15202B;" vertex="1" parent="1"><mxGeometry x="550" y="150" width="160" height="80" as="geometry"/></mxCell><mxCell id="localonly" value="chỉ LocalQwenProvider" style="rounded=1;arcSize=12;whiteSpace=wrap;html=1;fontSize=11;fillColor=#FFF2CC;strokeColor=#D6B656;fontColor=#15202B;" vertex="1" parent="1"><mxGeometry x="840" y="168" width="300" height="46" as="geometry"/></mxCell><mxCell id="build" value="dựng chuỗi (auto / groq / gemini /&lt;br&gt;openai_compatible)" style="rounded=1;arcSize=12;whiteSpace=wrap;html=1;fontSize=10.5;fillColor=#D4E1F5;strokeColor=#3F61A8;fontColor=#15202B;" vertex="1" parent="1"><mxGeometry x="280" y="268" width="320" height="50" as="geometry"/></mxCell><mxCell id="c1" value="nếu có GROQ_API_KEY và ĐƯỢC phép cloud&lt;br&gt;→ thêm GroqProvider" style="rounded=1;arcSize=12;whiteSpace=wrap;html=1;fontSize=9.5;fillColor=#FFF2CC;strokeColor=#D6B656;fontColor=#15202B;" vertex="1" parent="1"><mxGeometry x="80" y="344" width="380" height="46" as="geometry"/></mxCell><mxCell id="c2" value="nếu có GEMINI_API_KEY và ĐƯỢC phép cloud&lt;br&gt;→ thêm GeminiProvider" style="rounded=1;arcSize=12;whiteSpace=wrap;html=1;fontSize=9.5;fillColor=#FFF2CC;strokeColor=#D6B656;fontColor=#15202B;" vertex="1" parent="1"><mxGeometry x="80" y="402" width="380" height="46" as="geometry"/></mxCell><mxCell id="c3" value="nếu self-hosted (OpenAI-compatible) đã cấu hình&lt;br&gt;→ thêm OpenAICompatibleProvider" style="rounded=1;arcSize=12;whiteSpace=wrap;html=1;fontSize=9.5;fillColor=#FFF2CC;strokeColor=#D6B656;fontColor=#15202B;" vertex="1" parent="1"><mxGeometry x="80" y="460" width="380" height="50" as="geometry"/></mxCell><mxCell id="c4" value="luôn thêm LocalQwenProvider (cuối chuỗi)" style="rounded=1;arcSize=12;whiteSpace=wrap;html=1;fontSize=9.5;fillColor=#FFF2CC;strokeColor=#D6B656;fontColor=#15202B;" vertex="1" parent="1"><mxGeometry x="80" y="524" width="380" height="44" as="geometry"/></mxCell><mxCell id="groq" value="GroqProvider&lt;br&gt;(cloud)" style="rounded=1;arcSize=12;whiteSpace=wrap;html=1;fontSize=9.5;fillColor=#FFF2CC;strokeColor=#D6B656;fontColor=#15202B;" vertex="1" parent="FB"><mxGeometry x="20" y="68" width="146" height="64" as="geometry"/></mxCell><mxCell id="gem" value="GeminiProvider&lt;br&gt;(cloud)" style="rounded=1;arcSize=12;whiteSpace=wrap;html=1;fontSize=9.5;fillColor=#FFF2CC;strokeColor=#D6B656;fontColor=#15202B;" vertex="1" parent="FB"><mxGeometry x="179