<mxfile host="app.diagrams.net" type="device"><diagram name="W3 · Quyền riêng tư (WebApp) — Local-only · khóa API · chính sách URL" id="webapp-privacy-local-only"><mxGraphModel dx="900" dy="600" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1360" pageHeight="650" math="0" shadow="0"><root><mxCell id="0"/><mxCell id="1" parent="0"/><mxCell id="title" value="W3 · Quyền riêng tư (WebApp) — Local-only · khóa API · chính sách URL" style="text;html=1;fontSize=20;fontStyle=1;verticalAlign=middle;align=left;fontColor=#10202E;" vertex="1" parent="1"><mxGeometry x="40" y="14" width="1280" height="32" as="geometry"/></mxCell><mxCell id="LO" value="Local-only (Cài đặt → Quyền riêng tư)" style="swimlane;rounded=1;arcSize=4;startSize=34;html=1;whiteSpace=wrap;fontSize=14;fontStyle=1;fillColor=#F8CECC;strokeColor=#B85450;swimlaneFillColor=#FCECEB;fontColor=#10202E;verticalAlign=middle;align=left;spacingLeft=8;" vertex="1" parent="1"><mxGeometry x="40" y="64" width="620" height="196" as="geometry"/></mxCell><mxCell id="KEY" value="Khóa API — CHỈ nằm trong kho khóa (keyring) trên server" style="swimlane;rounded=1;arcSize=4;startSize=34;html=1;whiteSpace=wrap;fontSize=14;fontStyle=1;fillColor=#D4E1F5;strokeColor=#3F61A8;swimlaneFillColor=#EEF3FB;fontColor=#10202E;verticalAlign=middle;align=left;spacingLeft=8;" vertex="1" parent="1"><mxGeometry x="700" y="64" width="620" height="196" as="geometry"/></mxCell><mxCell id="lo1" value="CHẶN Groq · Gemini — không dữ liệu nào được gửi lên cloud" style="rounded=1;arcSize=12;whiteSpace=wrap;html=1;fontSize=11.5;fillColor=#F8CECC;strokeColor=#B85450;fontColor=#15202B;" vertex="1" parent="LO"><mxGeometry x="24" y="40" width="572" height="42" as="geometry"/></mxCell><mxCell id="lo2" value="CHO PHÉP model cục bộ và server tự host (mạng của bạn)" style="rounded=1;arcSize=12;whiteSpace=wrap;html=1;fontSize=11.5;fillColor=#D5E8D4;strokeColor=#82B366;fontColor=#15202B;" vertex="1" parent="LO"><mxGeometry x="24" y="90" width="572" height="42" as="geometry"/></mxCell><mxCell id="lo3" value="Không fallback ngầm sang cloud — báo lỗi rõ ràng, có hướng xử lý" style="rounded=1;arcSize=12;whiteSpace=wrap;html=1;fontSize=11.5;fillColor=#F8CECC;strokeColor=#B85450;fontColor=#15202B;" vertex="1" parent="LO"><mxGeometry x="24" y="140" width="572" height="42" as="geometry"/></mxCell><mxCell id="k1" value="keyring trên máy chủ chạy WebApp (Keychain · Credential Manager · Secret Service)" style="rounded=1;arcSize=12;whiteSpace=wrap;html=1;fontSize=11;fillColor=#D4E1F5;strokeColor=#3F61A8;fontColor=#15202B;" vertex="1" parent="KEY"><mxGeometry x="24" y="40" width="572" height="42" as="geometry"/></mxCell><mxCell id="k2" value="Trình duyệt chỉ nhận dạng che (4 ký tự cuối) — không bao giờ trả khóa đầy đủ" style="rounded=1;arcSize=12;whiteSpace=wrap;html=1;fontSize=11.5;fillColor=#D4E1F5;strokeColor=#3F61A8;fontColor=#15202B;" vertex="1" parent="KEY"><mxGeometry x="24" y="90" width="572" height="42" as="geometry"/></mxCell><mxCell id="k3" value="Kho khóa không khả dụng → cảnh báo rõ + TỪ CHỐI lưu (không âm thầm)" style="rounded=1;arcSize=12;whiteSpace=wrap;html=1;fontSize=11.5;fillColor=#D4E1F5;strokeColor=#3F61A8;fontColor=#15202B;" vertex="1" parent="KEY"><mxGeometry x="24" y="140" width="572" height="42" as="geometry"/></mxCell><mxCell id="note" value="Kiểm tra kết nối: GET /v1/models (kèm Bearer nếu có khóa) → nếu server không hỗ trợ, thử chat completion tối thiểu (max_tokens = 1).&lt;br&gt;KHÔNG bao giờ gửi nội dung tài liệu ra ngoài khi kiểm tra." style="rounded=1;arcSize=12;whiteSpace=wrap;html=1;fontSize=11.5;fillColor=#FFF2CC;strokeColor=#D6B656;fontColor=#15202B;" vertex="1" parent="1"><mxGeometry x="40" y="546" width="1280" height="56" as="geometry"/></mxCell><mxCell id="url" value="Chính sách URL — server LLM tự host" style="swimlane;rounded=1;arcSize=6;startSize=28;html=1;fontSize=13;fontStyle=1;fillColor=#FFF2CC;strokeColor=#D6B656;swimlaneFillColor=#FFFFFF;fontColor=#10202E;align=center;" vertex="1" parent="1"><mxGeometry x="40" y="296" width="620" height="178" as="geometry"/></mxCell><mxCell id="url_r0" value="HTTPS  &lt;b&gt;luôn cho phép&lt;/b&gt;" style="text;html=1;align=left;verticalAlign=middle;spacingLeft=8;fontSize=11;strokeColor=none;fillColor=none;fontColor=#243B4A;" vertex="1" parent="url"><mxGeometry x="0" y="28" width="620" height="24" as="geometry"/></mxCell><mxCell id="url_r1" value="HTTP → localhost / 127.0.0.1 / ::1  &lt;b&gt;cho phép&lt;/b&gt;" style="text;html=1;align=left;verticalAlign=middle;spacingLeft=8;fontSize=11;strokeColor=none;fillColor=none;fontColor=#243B4A;" vertex="1" parent="url"><mxGeometry x="0" y="52" width="620" height="24" as="geometry"/></mxCell><mxCell id="url_r2" value="HTTP → IP LAN riêng (10/8 · 172.16/12 · 192.168/16 · fc00::/7)  &lt;b&gt;bật tùy chọn + xác nhận&lt;/b&gt;" style="text;html=1;align=left;verticalAlign=middle;spacingLeft=8;fontSize=11;strokeColor=none;fillColor=none;fontColor=#243B4A;" vertex="1" parent="url"><mxGeometry x="0" y="76" width="620" height="24" as="geometry"/></mxCell><mxCell id="url_r3" value="HTTP → địa chỉ công cộng hoặc hostname  &lt;b&gt;từ chối&lt;/b&gt;" style="text;html=1;align=left;verticalAlign=middle;spacingLeft=8;fontSize=11;strokeColor=none;fillColor=none;fontColor=#243B4A;" vertex="1" parent="url"><mxGeometry x="0" y="100" width="620" height="24" as="geometry"/></mxCell><mxCell id="url_r4" value="URL chứa thông tin đăng nhập (user:pass@)  &lt;b&gt;từ chối&lt;/b&gt;" style="text;html=1;align=left;verticalAlign=middle;spacingLeft=8;fontSize=11;strokeColor=none;fillColor=none;fontColor=#243B4A;" vertex="1" parent="url"><mxGeometry x="0" y="124" width="620" height="24" as="geometry"/></mxCell><mxCell id="url_r5" value="Hạ cấp HTTPS xuống HTTP  &lt;b&gt;không bao giờ&lt;/b&gt;" style="text;html=1;align=left;verticalAlign=middle;spacingLeft=8;fontSize=11;strokeColor=none;fillColor=none;fontColor=#243B4A;" vertex="1" parent="url"><mxGeometry x="0" y="148" width="620" height="24" as="geometry"/></mxCell><mxCell id="probe" value="Kiểm tra kết nối self-hosted — các trạng thái hiển thị" style="swimlane;rounded=1;arcSize=6;startSize=28;html=1;fontSize=13;fontStyle=1;fillColor=#D5E8D4;strokeColor=#82B366;swimlaneFillColor=#FFFFFF;fontColor=#10202E;align=center;" vertex="1" parent="1"><mxGeometry x="700" y="296" width="620" height="226" as="geometry"/></mxCell><mxCell id="probe_r0" value="Đã kết nối (connected) — server &amp; model sẵn sàng" style="text;html=1;align=left;verticalAlign=middle;spacingLeft=8;fontSize=11;strokeColor=none;fillColor=none;fontColor=#243B4A;" vertex="1" parent="probe"><mxGeometry x="0" y="28" width="620" height="24" as="geometry"/></mxCell><mxCell id="probe_r1" value="Không truy cập được (unavailable)" style="text;html=1;align=left;verticalAlign=middle;spacingLeft=8;fontSize=11;strokeColor=none;fillColor=none;fontColor=#243B4A;" vertex="1" parent="probe"><mxGeometry x="0" y="52" width="620" height="24" as="geometry"/></mxCell><mxCell id="probe_r2" value="Xác thực thất bại (auth_failed — 401 · 403)" style="text;html=1;align=left;verticalAlign=middle;spacingLeft=8;fontSize=11;strokeColor=none;fillColor=none;fontColor=#243B4A;" vertex="1" parent="probe"><mxGeometry x="0" y="76" width="620" height="24" as="geometry"/></mxCell><mxCell id="probe_r3" value="Không tìm thấy model (model_not_found)" style="text;html=1;align=left;verticalAlign=middle;spacingLeft=8;fontSize=11;strokeColor=none;fillColor=none;fontColor=#243B4A;" vertex="1" parent="probe"><mxGeometry x="0" y="100" width="620" height="24" as="geometry"/></mxCell><mxCell id="probe_r4" value="Phản hồi không tương thích (incompatible)" style="text;html=1;align=left;verticalAlign=middle;spacingLeft=8;fontSize=11;strokeColor=none;fillColor=none;fontColor=#243B4A;" vertex="1" parent="probe"><mxGeometry x="0" y="124" width="620" height="24" as="geometry"/></mxCell><mxCell id="probe_r5" value="Hết thời gian chờ (timeout)" style="text;html=1;align=left;verticalAlign=middle;spacingLeft=8;fontSize=11;strokeColor=none;fillColor=none;fontColor=#243B4A;" vertex="1" parent="probe"><mxGeometry x="0" y="148" width="620" height="24" as="geometry"/></mxCell><mxCell id="probe_r6" value="Bị chính sách URL chặn (policy_blocked)" style="text;html=1;align=left;verticalAlign=middle;spacingLeft=8;fontSize=11;strokeColor=none;fillColor=none;fontColor=#243B4A;" vertex="1" parent="probe"><mxGeometry x="0" y="172" width="620" height="24" as="geometry"/></mxCell><mxCell id="probe_r7" value="Giới hạn ngữ cảnh quá nhỏ (context_insufficient)" style="text;html=1;align=left;verticalAlign=middle;spacingLeft=8;fontSize=11;strokeColor=none;fillColor=none;fontColor=#243B4A;" vertex="1" parent="probe"><mxGeometry x="0" y="196" width="620" height="24" as="geometry"/></mxCell></root></mxGraphModel></diagram></mxfile>