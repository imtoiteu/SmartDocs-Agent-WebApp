# SmartDocs-Agent — Environment Configuration
# ============================================
# Copy this file to .env and override only what you need:
#     cp .env.example .env
# The app runs with safe defaults if .env is absent. Lines starting with # are
# ignored. Every variable below is read either by the application code
# (config.py · agent/core/provider.py · services/ai_rewrite_service.py) or by
# the local runtime scripts in scripts/ (which translate the operator-facing
# names below into the exact variables the app + GLM server consume).
# Nothing here is decorative — no invented variables.

# ── Local runtime (read by scripts/) ───────────────────────────────────────────
# These are the knobs the scripts/*.sh launchers use. They are the recommended
# way to configure ports; the scripts map them onto the low-level app variables:
#   SMARTDOCS_PORT -> PORT              (web app)
#   GLM_PORT       -> GLM_OCR_API_URL   (GLM model server, via tools/glm_serve.sh)
SMARTDOCS_PORT=5002
GLM_PORT=8080
# Main-venv Python — the scripts resolve it automatically (./.venv, then
# ../.venv). REQUIRED: Python 3.10 (3.11 tolerated). 3.12/3.13/3.14 cannot
# install paddlepaddle / Pillow 10.2.0 and are rejected by setup.sh/check.sh.
# (GLM's separate venvs under GLM-OCR/ may use 3.10–3.12 — see setup_glm.sh.)
# Set this ONLY to pin a non-default venv interpreter:
# SMARTDOCS_PYTHON=/path/to/.venv/bin/python
# The model the GLM MLX server loads. tools/glm_serve.sh PRELOADS it at startup
# (so the port only opens once inference is actually ready) from the
# PROJECT-LOCAL HF cache ($MODEL_DIR/huggingface/hub). Pre-cache it while online
# with 'scripts/setup_glm.sh --precache-mlx' so a cold start never downloads.
GLM_MODEL=mlx-community/GLM-OCR-bf16
# Set to false to skip the startup preload (lazy mode: the first request loads
# the model; until then GLM OCR answers "still loading … retry"):
# GLM_PRELOAD=true
# Seconds start_glm.sh -b waits for model readiness before returning with a
# "still loading" note (0 = don't wait; scripts/start.sh uses a short 15s wait
# so the web app is never held up by a long model load):
# GLM_START_WAIT=90
# Master GLM off switch (forces GLM_OCR_MODE=disabled — see the GLM backend
# mode section below). The web app and the Legacy/VietOCR/Modern OCR engines
# ALWAYS run regardless of this flag; only the optional GLM OCR engine depends
# on it. A local server is started only when GLM_OCR_MODE=local_mlx
# (the default ONLY on macOS Apple Silicon).
ENABLE_GLM=true

# ── Offline / online mode ──────────────────────────────────────────────────────
# 1 = load HuggingFace / Argos / Stanza models ONLY from MODEL_DIR (no internet).
# 0 = allow HuggingFace to download missing models on demand.
# NOTE: PaddleOCR / PaddleX download their OWN model files on first use regardless
#       of this flag. Pre-fetch them while online with tools/warmup_modern_models.py.
OFFLINE=1

# ── Models directory ────────────────────────────────────────────────────────────
# Root for local HuggingFace models + Argos translation packages.
# Default: ./models   (set an absolute path to share a model store across machines)
# config.py DERIVES the cache locations from this — do not set them yourself
# (inherited HF_HOME/HF_HUB_CACHE values from your shell are overridden so setup
# and runtime can never split across ~/.cache/huggingface and the project cache):
#   HF_HOME                           -> $MODEL_DIR/huggingface
#   HF_HUB_CACHE / TRANSFORMERS_CACHE -> $MODEL_DIR/huggingface/hub
#   ARGOS_PACKAGES_DIR                -> $MODEL_DIR/argos/packages
# (PaddleOCR is the exception: PaddleX caches to ~/.paddlex/official_models,
#  override with PADDLE_PDX_CACHE_HOME. BOTH GLM models — the layout detector
#  and the MLX server model — also live in the project-local hub; see the GLM
#  section below.)
MODEL_DIR=./models

# ── Compute device ──────────────────────────────────────────────────────────────
# auto = CUDA (if present) → MPS (Apple Silicon) → CPU.   Options: auto | cpu | cuda | mps
DEVICE=auto
# Optional dtype override (blank = auto-select). Options: float32 | float16 | bfloat16
# DTYPE=

# ── Web server ──────────────────────────────────────────────────────────────────
HOST=0.0.0.0
# Low-level port the app binds. Leave this commented and use SMARTDOCS_PORT above
# (the scripts set PORT from it). An explicit PORT here still wins if you set it.
# PORT=5002
# Fixed secret = login sessions survive restarts. Blank = random key per start.
# SECRET_KEY=change-me-to-a-long-random-string
# Max upload size in MB (default 50)
# MAX_UPLOAD_MB=50
# Set to 1 ONLY when served behind HTTPS (marks session cookies Secure)
# SESSION_COOKIE_SECURE=0
# Timezone used to render timestamps in the UI
# DISPLAY_TZ=Asia/Ho_Chi_Minh

# ── Paths (blank = defaults under the project directory) ────────────────────────
# UPLOAD_DIR=
# DB_PATH=

# ── OCR engine (global default for the web UI) ──────────────────────────────────
# paddle | vietocr   (Modern + GLM are still selectable per-request in the UI)
OCR_ENGINE=paddle

# VietOCR runtime. Clean clones need models/vietocr/config.yml + the weights;
# 'scripts/setup_offline.sh' downloads vgg_transformer.pth AND generates
# config.yml (offline, from the installed vietocr package). Override the weights
# path with VIETOCR_WEIGHTS, or the architecture with VIETOCR_CONFIG.
# VIETOCR_DEVICE=cpu
# VIETOCR_CONFIG=vgg_transformer
# VIETOCR_WEIGHTS=

# ── GLM-OCR backend mode (cross-platform) ───────────────────────────────────────
# GLM-OCR (upstream: github.com/zai-org/GLM-OCR) is NOT macOS-only — pick how
# SmartDocs reaches it. Platform-aware default: local_mlx on macOS Apple
# Silicon, disabled on Windows/Linux (never assume a local MLX server exists).
# ENABLE_GLM=false (below) stays the master off switch.
#   GLM_OCR_MODE=local_mlx        # local mlx_vlm server — macOS Apple Silicon ONLY
#   GLM_OCR_MODE=external_server  # GLM served elsewhere: vLLM / SGLang / a Mac's MLX
#   GLM_OCR_MODE=maas_api         # Zhipu MaaS cloud API (key + internet required)
#   GLM_OCR_MODE=disabled         # GLM off; PaddleOCR/VietOCR are unaffected
#   GLM_OCR_MODE=ollama           # RESERVED — not verified in SmartDocs yet
# GLM_OCR_MODE=local_mlx
#
# external_server settings (Linux/Windows: deploy GLM-OCR separately with vLLM
# or SGLang on a GPU box — or point at a Mac running scripts/start_glm.sh —
# then connect SmartDocs as a client):
#   GLM_EXTERNAL_PROTOCOL=openai_compatible   # SUPPORTED: POST <url>/v1/chat/completions
#   GLM_EXTERNAL_PROTOCOL=sdk_server          # RESERVED (glmocr server /glmocr/parse) — not implemented yet
# GLM_OCR_API_URL below doubles as the external endpoint, e.g.
#   GLM_OCR_API_URL=http://192.168.1.50:8080  (the /v1/chat/completions path is appended)
# GLM_OCR_MODEL=                 # served model id (vLLM/SGLang require it)
# GLM_OCR_API_KEY=               # only if the external server enforces one
# GLM_OCR_VERIFY_SSL=false       # self-signed LAN certs: keep false
#
# maas_api settings (cloud passthrough — no local models/venvs used at OCR time):
# GLM_MAAS_API_URL=https://open.bigmodel.cn/api/paas/v4/layout_parsing
# GLM_MAAS_API_KEY=              # or ZHIPU_API_KEY (the SDK's own variable)
# GLM_MAAS_VERIFY_SSL=true
#
# ollama settings (RESERVED — do not rely on these until verified):
# GLM_OLLAMA_BASE_URL=http://localhost:11434
# GLM_OLLAMA_MODEL=

# GLM-OCR local_mlx runtime (Apple Silicon).
# CLEAN-CLONE DEFAULT: the vendored GLM-OCR inside THIS repo is used, i.e.
#   GLM_OCR_DIR   = <repo>/GLM-OCR
#   GLM python    = <repo>/GLM-OCR/.venv-mlx/bin/python  (or .venv-sdk)
#   config        = <repo>/GLM-OCR/mlx_config.yaml       (setup_glm.sh generates it)
# You do NOT need to set anything here to use the vendored copy — just run:
#   scripts/setup_glm.sh   then   scripts/start_glm.sh -b
#
# Override ONLY to point at an EXTERNAL GLM-OCR checkout (no repo paths hardcoded):
# GLM_OCR_DIR=/custom/path/to/GLM-OCR          # (legacy alias: GLM_ROOT)
# GLM_SDK_PYTHON=/custom/path/to/.venv/bin/python
# GLM_MLX_PYTHON=/custom/path/to/.venv-mlx/bin/python
# GLM_CONFIG_YAML=/custom/path/to/mlx_config.yaml
# Layout model for GLM self-hosted mode. glmocr REQUIRES pipeline.layout.model_dir;
# setup_glm.sh writes this value into mlx_config.yaml. Default is a Hugging Face id
# cached PROJECT-LOCALLY in $MODEL_DIR/huggingface/hub (same cache as every other
# model). Pre-cache it while online with 'scripts/setup_glm.sh --precache-layout'
# so runtime stays offline. May also be an absolute local checkpoint directory.
# GLM_LAYOUT_MODEL_DIR=PaddlePaddle/PP-DocLayoutV3_safetensors
# Full server URL the OCR adapter calls. Leave commented and use GLM_PORT above
# (the scripts derive this as http://localhost:${GLM_PORT}). Set it explicitly
# only to point at a non-default host/port.
# GLM_OCR_API_URL=http://localhost:8080
# GLM_TIMEOUT=300

# ── LLM provider layer (chat / AI rewrite / agent) ──────────────────────────────
# Where LLM completions come from:
#   LLM_PROVIDER=local_hf           # local Hugging Face model (offline-first DEFAULT)
#   LLM_PROVIDER=openai_compatible  # any /v1/chat/completions server (vLLM, llama.cpp
#                                   # server, LM Studio, …) — agent chain today;
#                                   # chat + AI rewrite still use the local model
#   LLM_PROVIDER=disabled           # chat/agent/AI-rewrite answer with a setup hint
# LLM_PROVIDER=local_hf
# Default LOCAL model for chat + rewrite + agent at once (the lightweight
# default, not the only option; QWEN_MODEL / CHAT_MODEL below still override):
# LOCAL_LLM_MODEL=Qwen/Qwen2.5-1.5B-Instruct
# Device for the local LLM: auto | cpu | mps | cuda (blank = CPU-safe defaults;
# QWEN_DEVICE / CHAT_DEVICE below still override):
# LOCAL_LLM_DEVICE=
# Sizing hint shown by /api/llm/status (low ≈ 1–2B CPU, medium ≈ 3–7B, high ≈ GPU):
# LOCAL_LLM_PROFILE=low
# OpenAI-compatible endpoint (for LLM_PROVIDER=openai_compatible):
# OPENAI_COMPATIBLE_BASE_URL=http://localhost:8000/v1
# OPENAI_COMPATIBLE_API_KEY=
# OPENAI_COMPATIBLE_MODEL=
# Feature switches (default on; LLM_PROVIDER=disabled turns all three off):
# ENABLE_CHAT=true
# ENABLE_AGENT=true
# ENABLE_REWRITE=true
# Wall-clock budget for one agent run (seconds): past it the agent stops calling
# tools and synthesizes a final answer from what it already has. 0 disables.
# AGENT_MAX_SECONDS=180

# ── Local AI models (must exist in MODEL_DIR when OFFLINE=1) ────────────────────
# DEFAULT LOCAL LLM: Qwen/Qwen2.5-1.5B-Instruct is the single default for chat,
# AI rewrite AND the agent's local provider. Larger models (e.g. 3B) are NOT used
# by default (unstable on Apple-Silicon MPS for this app) — opt in below.
# With OFFLINE=1 (the default) these load ONLY from MODEL_DIR — nothing is
# downloaded at runtime. Cache them ONCE while online with:
#   scripts/setup_offline.sh            # downloads the 1.5B default once
# then verify with: scripts/check_offline.sh
# Summarization "AI rewrite" + OCR text cleanup model
# QWEN_MODEL=Qwen/Qwen2.5-1.5B-Instruct
QWEN_DEVICE=cpu
# RAG chat models. Both default to the SAME 1.5B model above. To OPT IN to a
# larger primary (downloaded by setup_offline.py only when set here), uncomment:
# CHAT_MODEL=Qwen/Qwen2.5-3B-Instruct        # optional, opt-in only
# FALLBACK_CHAT_MODEL=Qwen/Qwen2.5-1.5B-Instruct
# CHAT_DEVICE=cpu
# PhoBERT — Vietnamese extractive summarization embeddings
# PHOBERT_MODEL=vinai/phobert-base-v2

# ── Agent LLM providers ─────────────────────────────────────────────────────────
# Selection:  auto (Groq → Gemini → Local Qwen) | local | groq | gemini
AGENT_LLM_PROVIDER=auto
# Groq (used by the agent AND as an AI-rewrite cloud fallback)
# GROQ_API_KEY=
# GROQ_MODEL=llama-3.3-70b-versatile
# Gemini
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.0-flash

# ── AI Rewrite cloud fallback (OPTIONAL) ────────────────────────────────────────
# Used only if the local Qwen rewrite model is unavailable.
# OPENAI_API_KEY=
# OPENROUTER_API_KEY=

# ── Advanced / performance (rarely needed) ──────────────────────────────────────
# Force torch CPU thread count for LLM generation (PaddleOCR collapses it to 1).
# LLM_TORCH_THREADS=
